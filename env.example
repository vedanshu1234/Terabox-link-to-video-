# TeraBox Bot — Environment Variables
# Render Dashboard mein ye sab set karo
# Local test ke liye: cp env.example .env

# [ZARURI] BotFather se
BOT_TOKEN=123456:ABC-DEFxxxxxxxxxxxxxxx

# [ZARURI] MongoDB Atlas connection string
# mongodb.com → Connect → Drivers → copy string → PASSWORD replace karo
MONGO_URI=mongodb+srv://botuser:PASSWORD@terabox-bot.xxxxx.mongodb.net/?retryWrites=true&w=majority

# [ZARURI on Render] Aapka Render URL
WEBHOOK_URL=https://terabox-bot-xxxx.onrender.com

# [ZARURI for ads] GPLink API key
GPLINK_API=your_gplink_api_key_here

# [Fixed] Render ka port
PORT=10000

# [Optional] TeraBox account cookie
COOKIE=

# [Optional] Customize karo
FREE_LINKS=3
COOLDOWN_HRS=7
