# ─────────────────────────────────────────────────────────────────────────────
# TeraBox Bot — .env file (local testing ke liye)
# Render pe ye sab Dashboard mein set hoga — yeh file sirf local ke liye hai
# ─────────────────────────────────────────────────────────────────────────────

# [ZARURI] Telegram Bot Token — @BotFather se
BOT_TOKEN=123456:ABC-DEFxxxxxxxxxxxxxxx

# [ZARURI on Render] Aapka public domain
# Local test mein khali rakhein → --polling mode chalega
WEBHOOK_URL=https://terabox-bot-xxxx.onrender.com

# [Render mein auto-set hoga] PostgreSQL URL
# Local test ke liye khali rakhein → SQLite use hogi
DATABASE_URL=

# [ZARURI for ads] GPLink API key — gplinks.com → Tools → Developer API
GPLINK_API=your_gplink_api_key_here

# [OPTIONAL] Server port
PORT=10000

# [OPTIONAL] TeraBox account cookie
COOKIE=

# [OPTIONAL] Customization
FREE_LINKS=3
COOLDOWN_HRS=7
